{
  "rewrites": [
    
    {
      "source": "/api/:path*",
      "destination": "https://api.base44.io/api/:path*"
    },
    {
      "source": "/app-logs/:path*",
      "destination": "https://api.base44.io/app-logs/:path*"
    },
    {
      "source": "/analytics/:path*",
      "destination": "https://api.base44.io/analytics/:path*"
    },
    {
      "source": "/(?!manifest.json|api/|app-logs/|analytics/).*",
      "destination": "/index.html"
    }
  ]
}
